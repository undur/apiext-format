<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  ILLUSTRATIVE EXAMPLE - not a shipping element, not normative.

  WOCheckBox is the clean case for a GENUINE type split that is also honest both ways (verified against
  the WO 5.5 source, com/webobjects/appserver/_private/WOCheckBox.java):

    `checked` PULLS via booleanValueInComponent() - i.e. read by TRUTHINESS, so its pull type is
    java.lang.Object interpretation="truthy" (any value, coerced to a boolean: null/0/false are false).
    `checked` PUSHES Boolean.valueOf(selected) back - a hard java.lang.Boolean, every time.

  So `checked` renders as a two-row split: Object (truthy) -> Boolean. It exercises BOTH the directionality
  split (different pull/push types) AND the truthy interpretation in a single binding. See
  docs/APIEXT_FORMAT.md, "Directionality" and "Interpretation".
-->
<wodefinitions>
	<wo class="WOCheckBox" wocomponentcontent="false" passthrough="true">

		<doc><![CDATA[A checkbox (`<input type="checkbox">`). Use **either** `checked` (a truthy in, a Boolean out) **or** `value`+`selection` (membership-style) — not both.]]></doc>

		<binding name="checked">
			<pull><type interpretation="truthy">java.lang.Object</type></pull>
			<push><type>java.lang.Boolean</type></push>
			<doc>The checked state. **Pulled** by truthiness to decide the initial state (`null`/`0`/`false` → unchecked); **pushed** back as a `java.lang.Boolean` — `true` if the user left it checked, `false` otherwise. Mutually exclusive with `value`.</doc>
		</binding>

		<binding name="value">
			<pull><type>java.lang.Object</type></pull>
			<doc>This checkbox's value (the `value` attribute). With `selection`, the box is checked when `selection` equals `value`. Mutually exclusive with `checked`.</doc>
		</binding>

		<binding name="selection" settable="YES">
			<pull><type>java.lang.Object</type></pull>
			<push><type>java.lang.Object</type></push>
			<doc>The selected value (used with `value`). On submit it is set to `value` when the box is checked, or nulled when unchecked.</doc>
		</binding>

		<binding name="name">
			<pull><type>java.lang.String</type></pull>
			<doc>The HTML form-field name (auto-assigned if unbound).</doc>
		</binding>

		<binding name="disabled" defaults="Boolean">
			<pull><type interpretation="truthy">java.lang.Object</type></pull>
			<doc>If truthy, renders the checkbox disabled (its `selection` won't be submitted).</doc>
		</binding>

		<validation message="A WOCheckBox uses either 'checked' or 'value', not both.">
			<bound name="checked"/>
			<bound name="value"/>
		</validation>

	</wo>
</wodefinitions>
